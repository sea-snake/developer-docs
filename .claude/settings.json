{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "failIfUnavailable": true,
    "filesystem": {
      "denyRead": ["~/.ssh", "~/.gnupg", "~/.aws", "~/.config/gh"]
    }
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit(**)",
      "Write(**)",
      "Read(**)",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Edit(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.json)",
      "Write(.claude/settings.local.json)"
    ],
    "deny": [
      "Bash(git push --force *)"
    ]
  }
}
