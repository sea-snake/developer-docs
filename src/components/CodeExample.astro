---
/**
 * CodeExample — code snippet with GitHub and ICP Ninja links.
 *
 * Renders a code block with two footer links:
 *   1. "Full example" → GitHub source at the pinned examples commit
 *   2. "Try in browser" → opens the full project in icp.ninja
 *
 * Usage in MDX:
 *
 *   <CodeExample example="send_http_get" lang="motoko">
 *
 *   ```motoko snippet="send_http_get/src/send_http_get_backend/main.mo#get_request"
 *   ```
 *
 *   </CodeExample>
 *
 *   <CodeExample example="send_http_get" lang="rust">
 *
 *   ```rust snippet="send_http_get/src/send_http_get_backend/src/lib.rs#get_request"
 *   ```
 *
 *   </CodeExample>
 *
 * Props:
 *   example  — example folder name (e.g. "send_http_get")
 *   lang     — language key: "motoko", "rust", or "js" (determines the
 *              subdirectory: motoko/, rust/, or hosting/)
 */
import { examplesCommit } from "../utils/examples-commit.mjs";

const LANG_TO_DIR: Record<string, string> = {
  motoko: "motoko",
  rust: "rust",
  js: "hosting",
};

interface Props {
  example: string;
  lang: string;
}

const { example, lang } = Astro.props;
const langDir = LANG_TO_DIR[lang] || lang;
const githubUrl = `https://github.com/dfinity/examples/tree/${examplesCommit}/${langDir}/${example}`;
const ninjaUrl = `https://icp.ninja/i?g=${githubUrl}`;
---

<div class="code-example">
  <slot />
  <div class="code-example-footer">
    <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="example-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
      </svg>
      Full example
    </a>
    <a href={ninjaUrl} target="_blank" rel="noopener noreferrer" class="example-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="5 3 19 12 5 21 5 3"/>
      </svg>
      Try in browser
    </a>
  </div>
</div>

<style>
  .code-example {
    position: relative;
  }

  .code-example-footer {
    display: flex;
    justify-content: flex-start;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .example-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    border: 1px solid var(--sl-color-gray-5);
    transition: color 0.15s, border-color 0.15s;
  }

  .example-link:hover {
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-3);
  }

  .example-link svg {
    flex-shrink: 0;
  }
</style>
