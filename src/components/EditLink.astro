---
/**
 * Custom EditLink override.
 *
 * Starlight generates edit URLs using the content collection path
 * (src/content/docs/...) but our real docs directory is docs/ —
 * src/content/docs/ is just a symlink. This override rewrites the
 * path so the GitHub edit link points to the canonical location.
 */
const rawUrl = Astro.locals.starlightRoute.editUrl;
const editUrl = rawUrl?.href.replace('/src/content/docs/', '/docs/');
---

{
	editUrl && (
		<a href={editUrl} class="sl-flex print:hidden">
			<svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
				<path d="M22 7.24a1 1 0 0 0-.29-.71l-4.24-4.24a1 1 0 0 0-1.1-.22 1 1 0 0 0-.32.22l-2.83 2.83L2.29 16.05a1 1 0 0 0-.29.71V21a1 1 0 0 0 1 1h4.24a1 1 0 0 0 .76-.29l10.87-10.93L21.71 8c.1-.1.17-.2.22-.33a1 1 0 0 0 0-.24v-.14l.07-.05ZM6.83 20H4v-2.83l9.93-9.93 2.83 2.83L6.83 20ZM18.17 8.66l-2.83-2.83 1.42-1.41 2.82 2.82-1.41 1.42Z"/>
			</svg>
			{Astro.locals.t('page.editLink')}
		</a>
	)
}

<style>
	@layer starlight.core {
		a {
			gap: 0.5rem;
			align-items: center;
			text-decoration: none;
			color: var(--sl-color-gray-3);
		}
		a:hover {
			color: var(--sl-color-white);
		}
		svg {
			font-size: 1.2em;
			width: 1em;
			height: 1em;
		}
	}
</style>
